{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "easyscrollrec",
  "version": "0.1.0",
  "identifier": "com.easyscrollrec.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Easy ScrollRec",
        "width": 560,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/easybrawto"
    ]
  }
}